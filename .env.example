# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-string

# Dashboard login credentials
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Set to 1 for production (uses waitress WSGI server, disables debug mode)
PRODUCTION=0
PORT=5000
LOG_LEVEL=INFO

# Data directory for config.json, sync_state.json, sync.log
# (Docker sets this to /app/data automatically — only change if needed)
# DATA_DIR=./data

# Optional: override config.json credentials via env vars
# ARENA_EMAIL=
# ARENA_PASSWORD=
# ARENA_WORKSPACE_ID=
# ODOO_URL=
# ODOO_DB=
# ODOO_USER=
# ODOO_PASSWORD=
